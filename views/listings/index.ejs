<% layout("/layouts/boilerplate") %>
<%= success %>

<style>
  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, #fe424d 0%, #ff6b35 50%, #f7931e 100%);
    color: white;
    padding: 4rem 2rem;
    text-align: center;
    margin: -1rem -1rem 2rem -1rem;
    border-radius: 0 0 24px 24px;
  }

  .hero-section h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .hero-section p {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .hero-search {
    display: flex;
    max-width: 600px;
    margin: 0 auto;
    background: white;
    border-radius: 50px;
    padding: 0.4rem 0.4rem 0.4rem 1.5rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .hero-search input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    color: #333;
    background: transparent;
  }

  .hero-search button {
    background: #fe424d;
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.6rem 1.5rem;
    font-size: 1rem;
    cursor: pointer;
    font-weight: bold;
  }

  .hero-search button:hover {
    background: #e03540;
  }

  /* Stats Bar */
  .stats-bar {
    display: flex;
    justify-content: center;
    gap: 3rem;
    padding: 1.5rem;
    background: white;
    border-radius: 16px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    margin-bottom: 2rem;
  }

  .stat-item {
    text-align: center;
  }

  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
    color: #fe424d;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #888;
    margin-top: 0.2rem;
  }

  /* Filters */
  #filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    border-bottom: 1px solid #eee;
    padding-bottom: 1rem;
    margin-bottom: 1rem;
  }

  .filter {
    text-align: center;
    margin-right: 2rem;
    margin-top: 1rem;
    opacity: 0.6;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .filter:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .filter.active {
    opacity: 1;
    border-bottom: 2px solid #fe424d;
    padding-bottom: 4px;
    color: #fe424d;
  }

  .filter p {
    font-size: 0.8rem;
    margin-bottom: 0;
    margin-top: 0.3rem;
  }

  .tax-info {
    display: none;
  }

  .tax-toggle {
    border: 1px solid #ddd;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 0rem;
    display: flex;
    align-items: center;
    margin-top: 1rem;
  }

  /* Listing Cards */
  .listing-card {
    border: none !important;
    border-radius: 16px !important;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .listing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.15) !important;
  }

  .listing-card img {
    border-radius: 16px !important;
    transition: transform 0.3s ease;
  }

  .listing-card:hover img {
    transform: scale(1.03);
  }

  .listing-link {
    text-decoration: none;
    color: inherit;
  }

  .listing-card .card-body {
    padding: 0.75rem 0.5rem;
  }

  .listing-price {
    color: #fe424d;
    font-weight: 700;
    font-size: 1rem;
  }

  .listing-location {
    color: #888;
    font-size: 0.85rem;
  }
</style>

<!-- Hero Section -->
<% if (!search && !filter) { %>
<div class="hero-section">
  <h1>✈️ Find Your Perfect Stay</h1>
  <p>Discover amazing places to stay around the world</p>
  <form class="hero-search" action="/listings" method="GET">
    <input type="search" name="search" placeholder="Search destinations, cities, countries..." />
    <button type="submit">🔍 Search</button>
  </form>
</div>
<% } %>

<!-- Stats Bar -->
<% if (!search && !filter) { %>
<div class="stats-bar">
  <div class="stat-item">
    <div class="stat-number"><%= totalListings %>+</div>
    <div class="stat-label">🏠 Total Listings</div>
  </div>
  <div class="stat-item">
    <div class="stat-number"><%= totalCountries %>+</div>
    <div class="stat-label">🌍 Countries</div>
  </div>
  <div class="stat-item">
    <div class="stat-number"><%= totalUsers %>+</div>
    <div class="stat-label">👥 Happy Travelers</div>
  </div>
</div>
<% } %>

<!-- Filters -->
<div id="filters">
  <a href="/listings?filter=trending" class="filter <%= (typeof filter !== 'undefined' && filter === 'trending') ? 'active' : '' %>">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>
  <a href="/listings?filter=rooms" class="filter <%= (typeof filter !== 'undefined' && filter === 'rooms') ? 'active' : '' %>">
    <div><i class="fa-solid fa-bed"></i></div>
    <p>Rooms</p>
  </a>
  <a href="/listings?filter=city" class="filter <%= (typeof filter !== 'undefined' && filter === 'city') ? 'active' : '' %>">
    <div><i class="fa-solid fa-mountain-city"></i></div>
    <p>Iconic Cities</p>
  </a>
  <a href="/listings?filter=mountain" class="filter <%= (typeof filter !== 'undefined' && filter === 'mountain') ? 'active' : '' %>">
    <div><i class="fa-solid fa-mountain"></i></div>
    <p>Mountain</p>
  </a>
  <a href="/listings?filter=castle" class="filter <%= (typeof filter !== 'undefined' && filter === 'castle') ? 'active' : '' %>">
    <div><i class="fa-brands fa-fort-awesome"></i></div>
    <p>Castles</p>
  </a>
  <a href="/listings?filter=pool" class="filter <%= (typeof filter !== 'undefined' && filter === 'pool') ? 'active' : '' %>">
    <div><i class="fa-solid fa-person-swimming"></i></div>
    <p>Amazing Pools</p>
  </a>
  <a href="/listings?filter=camping" class="filter <%= (typeof filter !== 'undefined' && filter === 'camping') ? 'active' : '' %>">
    <div><i class="fa-solid fa-campground"></i></div>
    <p>Camping</p>
  </a>
  <a href="/listings?filter=farm" class="filter <%= (typeof filter !== 'undefined' && filter === 'farm') ? 'active' : '' %>">
    <div><i class="fa-solid fa-cow"></i></div>
    <p>Farms</p>
  </a>
  <a href="/listings?filter=arctic" class="filter <%= (typeof filter !== 'undefined' && filter === 'arctic') ? 'active' : '' %>">
    <div><i class="fa-solid fa-snowflake"></i></div>
    <p>Arctic</p>
  </a>
  <a href="/listings?filter=dome" class="filter <%= (typeof filter !== 'undefined' && filter === 'dome') ? 'active' : '' %>">
    <div><i class="fa-solid fa-igloo"></i></div>
    <p>Domes</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<!-- Search/Filter Results Info -->
<% if (typeof filter !== 'undefined' && filter) { %>
  <div class="mt-3 d-flex align-items-center gap-2">
    <h5 class="mb-0">Filtered by: "<%= filter %>"</h5>
    <a href="/listings" class="btn btn-sm btn-outline-dark">Clear</a>
  </div>
<% } %>

<% if (typeof search !== 'undefined' && search) { %>
  <div class="mt-3 d-flex align-items-center gap-2">
    <h5 class="mb-0">Search results for: "<%= search %>"</h5>
    <a href="/listings" class="btn btn-sm btn-outline-dark">Clear</a>
  </div>
<% } %>

<% if (allListings.length === 0) { %>
  <div class="text-center mt-5">
    <h4>No listings found 😔</h4>
    <a href="/listings" class="btn btn-dark mt-3">Browse all listings</a>
  </div>
<% } %>

<!-- Listing Cards -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-3 mt-2">
  <% for(let listing of allListings){ %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card listing-card">
        <img src="<%= listing.image.url %>"
          class="card-img-top"
          alt="listing_image"
          style="height: 20rem; object-fit:cover;">
        <div class="card-body">
          <p class="card-text mb-1">
            <b><%= listing.title %></b>
          </p>
          <p class="listing-location mb-1">
            <i class="fa-solid fa-location-dot"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>
          <p class="listing-price mb-0">
            &#8377;<%= listing.price.toLocaleString("en-IN") %>
            <span style="font-weight:normal; color:#888; font-size:0.9rem;">/night</span>
            <i class="tax-info" style="font-size:0.8rem; color:#888;"> +18% GST</i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<script>
  let TaxSwitch = document.getElementById("switchCheckDefault");
  TaxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(info of taxInfo) {
      if(info.style.display != "inline"){
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>